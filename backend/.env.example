# ═══════════════════════════════════════════════════════════
# NIX AI Backend — Environment Variables
#
# Copy this to .env and fill in your values:
#   cp .env.example .env
# ═══════════════════════════════════════════════════════════

# ── Environment ──────────────────────────────────────────
ENV=development
DEBUG=true
LOG_LEVEL=INFO

# ── AWS ──────────────────────────────────────────────────
AWS_REGION=us-east-1
# For local dev, configure AWS credentials via ~/.aws/credentials
# or set these:
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# ── S3 ───────────────────────────────────────────────────
BUCKET_NAME=nixai-clinical-uploads
KB_BUCKET_NAME=nixai-clinical-kb
UPLOAD_PREFIX=uploads/
SYNTHETIC_PREFIX=synthetic/
PRESIGNED_URL_EXPIRY=3600

# ── SQS ──────────────────────────────────────────────────
# Leave empty for local dev (messages will be logged but not sent)
SQS_URL=

# ── DynamoDB ─────────────────────────────────────────────
DYNAMODB_TABLE=nixai-core

# ── Cognito ──────────────────────────────────────────────
COGNITO_USER_POOL_ID=us-east-1_rjx3Fv6lg
COGNITO_APP_CLIENT_ID=937sqn4ogsomo8d6stlapvpo9

# ── Bedrock ──────────────────────────────────────────────
BEDROCK_MODEL_ID=amazon.nova-lite-v1:0
# Leave empty for mock mode (returns fake AI responses)
BEDROCK_KB_ID=
BEDROCK_KB_MODEL_ARN=arn:aws:bedrock:us-east-1::foundation-model/amazon.nova-lite-v1:0

# ── Boardroom (Adversarial Council v2) ───────────────────
# Model for multi-agent debate. Nova Pro recommended for quality.
# Fallback to nova-lite if Nova Pro not enabled in your Bedrock console.
BOARDROOM_MODEL_ID=us.amazon.nova-pro-v1:0

# ── CORS ─────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
